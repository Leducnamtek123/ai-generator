NODE_ENV=development
APP_PORT=8000
APP_NAME="AI Generator API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:8000

DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password_here
DATABASE_NAME=navlinx
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# MinIO (S3 Compatible)
FILE_DRIVER=s3
AWS_S3_ENDPOINT=http://localhost:9000
ACCESS_KEY_ID=minioadmin
SECRET_ACCESS_KEY=minioadmin
AWS_S3_REGION=us-east-1
AWS_DEFAULT_S3_BUCKET=ai-generator
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=AIGenerator
MAIL_CLIENT_PORT=1080

AUTH_JWT_SECRET=your_jwt_secret_here
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_SECRET=your_refresh_secret_here
AUTH_REFRESH_TOKEN_EXPIRES_IN=7d
AUTH_FORGOT_SECRET=your_forgot_secret_here
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=your_confirm_email_secret_here
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# Redis
WORKER_HOST=redis://localhost:6379/1
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ====== AI Provider Configuration ======

# Image Generation
IMAGE_GEN_PROVIDER=n8n
LEONARDO_API_KEY=your_leonardo_api_key_here
LEONARDO_MODEL_ID=phoenix
OPENAI_API_KEY=your_openai_api_key_here

# Video Generation
VIDEO_GEN_PROVIDER=n8n

# Upscaler
UPSCALER_PROVIDER=n8n

# Prompt Enhancer
PROMPT_ENHANCER_PROVIDER=n8n

# ====== n8n Webhook URLs ======
# Core generation webhooks
N8N_IMAGE_WEBHOOK_URL=https://your-n8n-url.com/webhook/image
N8N_VIDEO_WEBHOOK_URL=https://your-n8n-url.com/webhook/video
N8N_UPSCALE_WEBHOOK_URL=https://your-n8n-url.com/webhook/upscale
N8N_PROMPT_WEBHOOK_URL=https://your-n8n-url.com/webhook/prompt

# Audio webhooks
N8N_MUSIC_WEBHOOK_URL=https://your-n8n-url.com/webhook/music
N8N_SFX_WEBHOOK_URL=https://your-n8n-url.com/webhook/sfx
N8N_VOICE_WEBHOOK_URL=https://your-n8n-url.com/webhook/voice

# Video processing webhooks
N8N_LIPSYNC_WEBHOOK_URL=https://your-n8n-url.com/webhook/lipsync
N8N_VIDEO_UPSCALE_WEBHOOK_URL=https://your-n8n-url.com/webhook/video-upscale

# Image processing webhooks
N8N_BG_REMOVE_WEBHOOK_URL=https://your-n8n-url.com/webhook/bg-remove
N8N_SKETCH_WEBHOOK_URL=https://your-n8n-url.com/webhook/sketch-to-image
N8N_VARIATIONS_WEBHOOK_URL=https://your-n8n-url.com/webhook/variations
N8N_CAMERA_CHANGE_WEBHOOK_URL=https://your-n8n-url.com/webhook/camera-change
N8N_ICON_GEN_WEBHOOK_URL=https://your-n8n-url.com/webhook/icon-gen
N8N_IMAGE_EXTEND_WEBHOOK_URL=https://your-n8n-url.com/webhook/image-extend
N8N_MOCKUP_WEBHOOK_URL=https://your-n8n-url.com/webhook/mockup
N8N_SKIN_ENHANCE_WEBHOOK_URL=https://your-n8n-url.com/webhook/skin-enhance

# Fallback generic webhook (used when type-specific webhook is not configured)
N8N_GENERIC_WEBHOOK_URL=https://your-n8n-url.com/webhook/generic

# Mail
MAIL_HOST=smtp.example.com
