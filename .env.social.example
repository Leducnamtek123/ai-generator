# Social Hub Integration Keys
# Copy these to your main .env file and fill in the values

# Global Security
SOCIAL_ENCRYPTION_KEY="your_32_character_long_secret_key_here"

# Facebook Graph API
FACEBOOK_CLIENT_ID="your_facebook_app_id"
FACEBOOK_CLIENT_SECRET="your_facebook_app_secret"
FACEBOOK_CALLBACK_URL="${BACKEND_DOMAIN}/v1/social-hub/auth/facebook/callback"

# X (Twitter) API - OAuth 1.0a keys
X_API_KEY="your_x_api_key"
X_API_SECRET="your_x_api_secret"
X_CALLBACK_URL="${BACKEND_DOMAIN}/v1/social-hub/auth/twitter/callback"
# X (Twitter) OAuth 2.0 PKCE keys
TWITTER_CLIENT_ID="your_twitter_oauth2_client_id"
TWITTER_CLIENT_SECRET="your_twitter_oauth2_client_secret"

# Facebook aliases (adapters use both naming conventions)
FACEBOOK_APP_ID="${FACEBOOK_CLIENT_ID}"
FACEBOOK_APP_SECRET="${FACEBOOK_CLIENT_SECRET}"

# LinkedIn API
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
LINKEDIN_CALLBACK_URL="${BACKEND_DOMAIN}/v1/social-hub/auth/linkedin/callback"

# Domain Configuration (Set these in your main .env)
# BACKEND_DOMAIN="http://localhost:3000"
# FRONTEND_DOMAIN="http://localhost:3001"
