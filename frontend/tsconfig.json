{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/tailwind": [
        "./src/styles/tailwind.css"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/layouts": [
        "./src/components/layouts/index.ts"
      ],
      "@/layouts/*": [
        "./src/components/layouts/*"
      ],
      "@/widgets": [
        "./src/components/widgets/index.ts"
      ],
      "@/widgets/*": [
        "./src/components/widgets/*"
      ],
      "@/ui": [
        "./src/components/ui/index.ts"
      ],
      "@/ui/*": [
        "./src/components/ui/*"
      ],
      "@/hooks": [
        "./src/hooks/index.ts"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/data": [
        "./src/data/index.ts"
      ],
      "@/data/*": [
        "./src/data/*"
      ],
      "@/schemas": [
        "./src/schemas/index.ts"
      ],
      "@/schemas/*": [
        "./src/schemas/*"
      ],
      "@/stores/*": [
        "./src/stores/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/constants/*": [
        "./src/constants/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/providers/*": [
        "./src/providers/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
